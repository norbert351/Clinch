{
  "name": "clinch-api",
  "version": "1.0.0",
  "description": "Clinch Web3 escrow platform API server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "drizzle-kit migrate",
    "generate": "drizzle-kit generate",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^3.3.8",
    "pg": "^8.13.1",
    "postgres": "^3.4.9",
    "postgres-js": "^0.1.0",
    "resend": "^4.0.0",
    "siwe": "^2.3.2",
    "socket.io": "^4.8.1",
    "viem": "^2.21.54",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
